# feed-manager-ui — environment variables

# The base URL of your feedgen instance's admin API.
# This is the URL where feedgen's /admin/* routes are served.
# Examples:
#   http://localhost:3000        (local dev)
#   https://feeds.babesky.cloud (production)
FEEDGEN_ADMIN_URL=http://localhost:3000

# If your feedgen admin API is behind a proxy that requires a Bearer token
# for machine-to-machine access (e.g. the UI server authenticating on behalf
# of dashboard views), set it here. Leave empty to pass through the
# browser's cookies/session instead.
# FEEDGEN_ADMIN_BEARER_TOKEN=
